{
    "name": "microscrap/gpio",
    "description": "Unix gpiod Bindings for The PHP Posi Extension",
    "type": "library",
    "version": "0.5.1",
    "keywords": ["framework", "scrapyard-io"],
    "license": "MIT",
    "homepage": "https://dosr.projectsaturnstudios.com",
    "authors": [
        {
            "name": "Angel Gonzalez",
            "email": "angel@projectsaturnstudios.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-posi": "^0.5.0",
        "microscrap/posix": "^0.5.0"
    },
    "autoload": {
        "psr-4": {
            "Microscrap\\Bindings\\GPIO\\": "src/"
        },
        "files": [
            "src/Helpers/gpio-chip.php",
            "src/Helpers/gpio-chip-info.php",
            "src/Helpers/gpio-info-event.php",
            "src/Helpers/gpio-edge-event.php",
            "src/Helpers/gpio-edge-event-buffer.php",
            "src/Helpers/gpio-line-info.php",
            "src/Helpers/gpio-line-request.php",
            "src/Helpers/gpio-line-config.php",
            "src/Helpers/gpio-line-settings.php",
            "src/Helpers/gpio-request-config.php",
            "src/Helpers/gpio-misc.php",
            "src/Helpers/gpio-internal.php"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
